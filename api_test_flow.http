### ============================================================
### AEYEOT Backend - Complete API Test Flow
### 包含 Regression (sample_data_reg_multi_white.csv)
###      Classification (sample_data_cls_multi_white.csv)
### 使用 instrument_config.json 作為儀器參數
### ============================================================
### 使用說明:
###   1. 啟動服務: uvicorn main:app --reload
###   2. 依序執行各段落，將回傳的 ID 貼入下方對應的變數
###   3. {{...}} 為需手動填入的動態變數
### ============================================================

#@baseUrl = http://localhost:8000
@baseUrl = http://192.168.1.200
#@baseUrl = http://localhost
# ============================================================
# [0] 健康檢查
# ============================================================

### 0-1. Health check
GET {{baseUrl}}/health

### 0-2. Root
GET {{baseUrl}}/

# ============================================================
# [BLOCK A] REGRESSION 訓練 Pipeline
# sample_data_reg_multi_white.csv + instrument_config.json
# 成分: Water, Protein, Fat, Brix
# ============================================================

# ── A-1. 上傳 CSV (Regression) ───────────────────────────────

### A-1-1. 上傳 Regression CSV + instrument_config.json
# 回傳: { "file_id": "...", "filename": "...", "task_category": "regression", ... }
# 將 file_id 填入 @regFileId
POST {{baseUrl}}/api/upload/
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="file"; filename="20220727 NIR分析豆渣實驗值對照表.csv"
Content-Type: text/csv

< 20220727 NIR分析豆渣實驗值對照表.csv
--boundary
Content-Disposition: form-data; name="instrument_config"; filename="instrument_config.json"
Content-Type: application/json

< instrument_config.json
--boundary
Content-Disposition: form-data; name="task_category"

regression
--boundary--

###
@regFileId = 69f08c9741fc90e81c604358

### A-1-2. 列出所有已上傳檔案
#GET {{baseUrl}}/api/upload/

### A-1-3. 查詢單一檔案資訊 (從MongoDB取，無光譜數值)
GET {{baseUrl}}/api/upload/{{regFileId}}

### A-1-4. 預覽 CSV 內容（含 wavelengths, raw 無吸收換算）
GET {{baseUrl}}/api/upload/{{regFileId}}/preview

### A-1-5. 預覽 Absorbance 轉換後的光譜（需要 instrument_config 與 White row）
GET {{baseUrl}}/api/upload/{{regFileId}}/absorbance

# ── A-2. 查詢成分 (Components) ───────────────────────────────

### A-2-1. 查詢此檔案的所有成分
GET {{baseUrl}}/api/preprocessing/components/{{regFileId}}

### A-2-2. 查詢全部檔案的所有成分 (跨檔案去重)
#GET {{baseUrl}}/api/preprocessing/components

# ── A-3. 前處理 (Preprocessing) - Regression ─────────────────

### A-3-1. 執行前處理：SNV only，成分=Water
# 回傳: { "preprocessing_id": "...", "status": "running" }
# 將 preprocessing_id 填入 @regPrepId1
POST {{baseUrl}}/api/preprocessing/execute
Content-Type: application/json

{
  "file_id": "{{regFileId}}",
  "component": "Moisture content(%)",
  "methods": {
    "snv": true,
    "sg": null,
    "derivative": null,
    "normalization": null,
    "wavelength_selection": null
  }
}

###
@regPrepId1 = 69f0911641fc90e81c604388

### A-3-2. 查詢前處理狀態（輪詢直到 status=completed）
GET {{baseUrl}}/api/preprocessing/status/{{regPrepId1}}

### A-3-3. 取得前處理結果（含處理後光譜資料）
GET {{baseUrl}}/api/preprocessing/{{regPrepId1}}

### A-3-4. 執行前處理：SNV + SG + 一階微分，成分=Protein
# 等前一個任務完成再執行
POST {{baseUrl}}/api/preprocessing/execute
Content-Type: application/json

{
  "file_id": "{{regFileId}}",
  "component": "Moisture content(%)",
  "methods": {
    "snv": true,
    "sg": {
      "window_size": 15,
      "polynomial_order": 3
    },
    "derivative": {
      "order": 1
    },
    "normalization": null,
    "wavelength_selection": null
  }
}

###
@regPrepId2 = 69f0911641fc90e81c604388

### A-3-5. 查詢前處理狀態 - Protein
GET {{baseUrl}}/api/preprocessing/status/{{regPrepId2}}

### A-3-6. 執行前處理：SNV + SG + 二階微分 + Normalization(mean)，成分=Fat
POST {{baseUrl}}/api/preprocessing/execute
Content-Type: application/json

{
  "file_id": "{{regFileId}}",
  "component": "Moisture content(%)",
  "methods": {
    "snv": true,
    "sg": {
      "window_size": 15,
      "polynomial_order": 3
    },
    "derivative": {
      "order": 2
    },
    "normalization": {
      "type": "mean"
    },
    "wavelength_selection": {
      "method": "manual_clip",
      "manual_start": 900,
      "manual_end": 1300,
      "vip_threshold": null,
      "top_n": null,
      "n_iters": null,
      "k_fold": null
    }
  }
}

###
@regPrepId3 = 69f0911641fc90e81c604388

### A-3-7. 查詢前處理狀態 - Fat
GET {{baseUrl}}/api/preprocessing/status/{{regPrepId3}}

### A-3-8. 執行前處理：SNV + 波長選擇(manual_clip 900~1300)，成分=Brix
POST {{baseUrl}}/api/preprocessing/execute
Content-Type: application/json

{
  "file_id": "{{regFileId}}",
  "component": "Brix",
  "methods": {
    "snv": true,
    "sg": null,
    "derivative": null,
    "normalization": null,
    "wavelength_selection": {
      "method": "manual_clip",
      "manual_start": 900,
      "manual_end": 1300,
      "vip_threshold": null,
      "top_n": null,
      "n_iters": null,
      "k_fold": null
    }
  }
}

###
@regPrepId4 = 69f0911641fc90e81c604388
GET {{baseUrl}}/api/preprocessing/status/{{regPrepId4}}

### A-3-9. 執行前處理：SNV + 波長選擇(VIP)，成分=Water
POST {{baseUrl}}/api/preprocessing/execute
Content-Type: application/json

{
  "file_id": "{{regFileId}}",
  "component": "Water",
  "methods": {
    "snv": true,
    "sg": null,
    "derivative": null,
    "normalization": null,
    "wavelength_selection": {
      "method": "VIP",
      "manual_start": null,
      "manual_end": null,
      "vip_threshold": 1.0,
      "top_n": null,
      "n_iters": null,
      "k_fold": 5
    }
  }
}

###
@regPrepId5 = 69f0911641fc90e81c604388
GET {{baseUrl}}/api/preprocessing/status/{{regPrepId5}}

### A-3-10. 查詢前處理歷史（依檔案）
#GET {{baseUrl}}/api/preprocessing/history/{{regFileId}}

### A-3-11. 查詢特定成分的前處理歷史
#GET {{baseUrl}}/api/preprocessing/history/{{regFileId}}?component=Water

### A-3-12. 查詢全部前處理歷史
#GET {{baseUrl}}/api/preprocessing/history

# ── A-4. 模型訓練 (Training) - Regression ────────────────────

### A-4-1. 訓練 Regression：PLS（使用 Water 前處理結果，grid_search=false）
# 回傳: { "training_job_id": "...", "status": "running" }
# 將 training_job_id 填入 @regJobId1
POST {{baseUrl}}/api/modeling/train
Content-Type: application/json

{
  "file_id": "{{regFileId}}",
  "preprocessing_id": "{{regPrepId1}}",
  "task_category": "regression",
  "models": {
    "PLS": {
      "enabled": true,
      "params": {
        "n_components": 7
      }
    },
    "SVR": {
      "enabled": false,
      "params": {}
    },
    "RF": {
      "enabled": false,
      "params": {}
    },
    "XGBoost": {
      "enabled": false,
      "params": {}
    },
    "CNN": {
      "enabled": false,
      "params": {"epochs": 50, "batch_size": 16, "learning_rate": 0.001}
    }
  },
  "hyperparameter_tuning": {
    "grid_search": false,
    "k_fold": 5
  }
}

###
@regJobId1 = 69f0913441fc90e81c604392

### A-4-2. 查詢訓練狀態（輪詢直到 status=completed）
GET {{baseUrl}}/api/modeling/status/{{regJobId1}}

### A-4-5. 訓練 Regression：啟用 grid_search，PLS + RF
POST {{baseUrl}}/api/modeling/train
Content-Type: application/json

{
  "file_id": "{{regFileId}}",
  "preprocessing_id": "{{regPrepId1}}",
  "task_category": "regression",
  "models": {
    "PLS": {
      "enabled": true,
      "params": {
        "n_components": 5
      }
    },
    "SVR": {
      "enabled": false,
      "params": {}
    },
    "RF": {
      "enabled": true,
      "params": {
        "n_estimators": 50,
        "max_depth": 5
      }
    },
    "XGBoost": {
      "enabled": false,
      "params": {}
    },
    "CNN": {
      "enabled": false,
      "params": {"epochs": 50, "batch_size": 16, "learning_rate": 0.001}
    }
  },
  "hyperparameter_tuning": {
    "grid_search": true,
    "k_fold": 5
  }
}

