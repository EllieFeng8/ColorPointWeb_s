# ── B-5. 評估 (Evaluation) - Classification ──────────────────

### B-5-1. 取得分類訓練任務的評估結果(可以用來畫圖)
# 回傳格式 (Array，每個元素對應一個模型)：
#
# [
#   {
#     "id": "<evaluation_result_id>",
#     "trained_model_id": "<trained_model_id>",
#     "training_job_id": "<training_job_id>",
#     "model_name": "SVC_Fruit_SNV_SG_v1",
#     "task_category": "classification",
#
#     "training_metrics": {
#       "accuracy": 0.95,
#       "auc": 0.97,
#       "precision_score": 0.94,
#       "recall_score": 0.93,
#       "f1_score": 0.93,
#       "confusion_matrix": {
#         "labels":    ["Apple", "Banana", "Lemon", "Mango"],   ← 前台顯示用（軸標籤）
#         "label_ids": [0, 1, 2, 3],                            ← 對應 class_map key 的整數索引
#         "class_map": {                                         ← 索引 → 名稱對照
#           "0": "Apple",
#           "1": "Banana",
#           "2": "Lemon",
#           "3": "Mango"
#         },
#         "class_onehot_map": {                                  ← 名稱 → one-hot 向量
#           "Apple":  [1, 0, 0, 0],
#           "Banana": [0, 1, 0, 0],
#           "Lemon":  [0, 0, 1, 0],
#           "Mango":  [0, 0, 0, 1]
#         },
#         "data": [                                              ← N×N matrix，row=實際類別，col=預測類別
#           [8, 1, 0, 0],  ← 實際=Apple:  預測Apple=8, Banana=1, Lemon=0, Mango=0
#           [0, 7, 1, 0],  ← 實際=Banana: 預測Apple=0, Banana=7, Lemon=1, Mango=0
#           [0, 0, 6, 1],  ← 實際=Lemon:  預測Apple=0, Banana=0, Lemon=6, Mango=1
#           [1, 0, 0, 9]   ← 實際=Mango:  預測Apple=1, Banana=0, Lemon=0, Mango=9
#         ]
#       }
#     },
#
#     "testing_metrics": { ... 同 training_metrics 格式 ... },
#
#     "training_chart_data": [
#       { "label": "H1", "predicted": 1.0, "actual": 1.0 },
#       { "label": "H2", "predicted": 0.0, "actual": 1.0 },
#       ...
#     ],
#     "testing_chart_data": [ ... 同 training_chart_data 格式 ... ]
#   }
# ]
#
# ─── 前台讀取 confusion_matrix 對應位置的方式 ───────────────────
#
# const ev = results[0];                          // 選第一個模型的評估結果
# const cm = ev.testing_metrics.confusion_matrix;
#
# // cm.labels[i]        → 第 i 個類別的顯示名稱
# // cm.data[i][j]       → 實際=labels[i]、預測=labels[j] 的樣本數
# // 對角線 cm.data[i][i] → 預測正確的樣本數
#
# // 取得某格的意義：
# // cm.data[2][3] = 1  → 實際是 Lemon (i=2) 被預測成 Mango (j=3) 的有 1 筆
#
# // 轉換成 ECharts heatmap 三元組 [x(col=pred), y(row=actual), value]：
# const heatmapData = [];
# for (let row = 0; row < cm.data.length; row++) {
#   for (let col = 0; col < cm.data[row].length; col++) {
#     heatmapData.push([col, row, cm.data[row][col]]);
#   }
# }
# // xAxis.data = cm.labels  (Predicted)
# // yAxis.data = cm.labels  (Actual)
# // 注意：row=y=Actual，col=x=Predicted，不可顛倒
#
# // 取得每個類別的 precision / recall：
# // precision[j] = cm.data[j][j] / sum(cm.data[*][j])  (第 j 欄的對角值 / 欄合計)
# // recall[i]    = cm.data[i][i] / sum(cm.data[i][*])  (第 i 列的對角值 / 列合計)
GET {{baseUrl}}/api/evaluation/results/{{clsJobId1}}

### B-5-2. 取得多模型訓練任務的評估結果
#GET {{baseUrl}}/api/evaluation/results/{{clsJobId2}}

###
@clsModelId1 = 69e8ccfe5299d4be0f442ea3

### B-5-3. 取得分類模型詳情
GET {{baseUrl}}/api/evaluation/model/{{clsModelId1}}

# 備註：classification metrics 會包含
